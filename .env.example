# Copy to `.env` for local development and Docker Compose:
#   cp .env.example .env
#
# Vercel: set the same variables in Project Settings → Environment Variables
# (do not commit `.env`). Use `vercel env pull` locally if you want a synced file.
#
# Docker Compose uses host `db` in DATABASE_URL. For `next dev` on the host machine,
# override in `.env.local` with `@localhost` (Next.js loads `.env` then `.env.local`).

POSTGRES_USER=rekaz
POSTGRES_PASSWORD=rekaz
POSTGRES_DB=rekaz

DATABASE_URL="postgresql://rekaz:rekaz@db:5432/rekaz"
JWT_SECRET="change-me-to-a-long-random-string"

NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
